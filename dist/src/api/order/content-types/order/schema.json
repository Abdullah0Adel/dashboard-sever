{
    "kind": "collectionType",
    "collectionName": "orders",
    "info": {
        "singularName": "order",
        "pluralName": "orders",
        "displayName": "Order"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "orderNumber": {
            "type": "string"
        },
        "clientName": {
            "type": "string"
        },
        "email": {
            "type": "email"
        },
        "phone": {
            "type": "string"
        },
        "address": {
            "type": "string"
        },
        "orderDate": {
            "type": "datetime"
        },
        "orderStatus": {
            "type": "enumeration",
            "enum": [
                "pending",
                "shipped",
                "completed",
                "cancelled"
            ]
        },
        "deliveryFee": {
            "type": "decimal"
        },
        "total": {
            "type": "decimal"
        },
        "order_items": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::order-item.order-item",
            "mappedBy": "order"
        }
    }
}
